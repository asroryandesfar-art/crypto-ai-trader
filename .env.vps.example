# Copy this file to .env on the VPS, then fill the real keys there.
# Never send this file back after filling secrets.

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_ACCOUNT_TYPE=futures

# Start with paper. Use ./deploy/enable_live_vps.sh after preflight passes.
TRADING_MODE=paper
LIVE_TRADING=false
LIVE_TRADING_LOCKDOWN=true
LIVE_LOCKDOWN_REASON=VPS installed. Live mode has not passed explicit preflight yet.
LIVE_ORDER_CONFIRMATION=

# Keep this small until you have watched the bot for a while.
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
MAX_SYMBOLS_PER_CYCLE=20
MAX_RISK_PER_TRADE=1
DAILY_MAX_LOSS=3
MAX_LEVERAGE=1
CONFIDENCE_THRESHOLD=75
MAX_OPEN_POSITIONS=1
MAX_LIVE_ORDER_USDT=15
MIN_LIVE_ORDER_USDT=5
LIVE_STOP_LOSS_PCT=2
LIVE_TAKE_PROFIT_PCT=4

DATABASE_URL=sqlite:///./crypto_trader.db
REFRESH_INTERVAL=30
LOG_LEVEL=INFO

# Set this before exposing dashboard to the internet.
DASHBOARD_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

TIMEFRAMES=15m,1h,4h
LOOKBACK_CANDLES=100
BINANCE_RATE_LIMIT=10
COINGECKO_RATE_LIMIT=5
ENABLE_HEDGING=true
BINANCE_POSITION_MODE=one-way
EMERGENCY_STOP=false
