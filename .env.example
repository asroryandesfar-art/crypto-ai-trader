# ============================================
# GROQ API Configuration
# ============================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ============================================
# BINANCE API Configuration
# ============================================
BINANCE_API_KEY=

BINANCE_SECRET_KEY=

# ============================================
# Trading Mode Configuration
# ============================================
# IMPORTANT: Set to 'true' only when ready for LIVE trading
LIVE_TRADING=false

# Trading mode: 'paper', 'backtest', or 'live'
TRADING_MODE=paper

# Hard live-trading kill switch. Keep true until live preflight is clean.
LIVE_TRADING_LOCKDOWN=true
LIVE_LOCKDOWN_REASON=Live trading is locked until Binance preflight passes.

# Exchange to use
EXCHANGE=binance
BINANCE_ACCOUNT_TYPE=futures

# ============================================
# Trading Symbols
# ============================================
# Comma-separated list of symbols to trade
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# ============================================
# Risk Management Parameters
# ============================================
# Maximum risk per trade as percentage (recommended: 1%)
MAX_RISK_PER_TRADE=1

# Maximum daily loss as percentage (recommended: 3%)
DAILY_MAX_LOSS=3

# Maximum leverage allowed (recommended: 1, hard max: 20)
MAX_LEVERAGE=1

# Minimum confidence score to execute trade (0-100, recommended: 75)
CONFIDENCE_THRESHOLD=75

# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=3

# Extra live-order safety gate. Required value before real orders are allowed:
# I_ACCEPT_REAL_MONEY_RISK
LIVE_ORDER_CONFIRMATION=

# Hard cap for any single live order notional in USDT
MAX_LIVE_ORDER_USDT=15

# Skip live orders smaller than this notional in USDT
MIN_LIVE_ORDER_USDT=5

# Exchange-side protective stop/take-profit percentages for live futures longs
LIVE_STOP_LOSS_PCT=2
LIVE_TAKE_PROFIT_PCT=4

# ============================================
# Telegram Notifications (Optional)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///./crypto_trader.db
REFRESH_INTERVAL=30

# ============================================
# Market Data Configuration
# ============================================
# Timeframes for technical analysis
TIMEFRAMES=15m,1h,4h

# Number of candles to fetch for analysis
LOOKBACK_CANDLES=100
MAX_SYMBOLS_PER_CYCLE=50

# ============================================
# API Rate Limiting
# ============================================
# Binance rate limit (requests per second)
BINANCE_RATE_LIMIT=10

# CoinGecko rate limit (requests per second)
COINGECKO_RATE_LIMIT=5

# ============================================
# Hedge Configuration
# ============================================
# Enable hedging strategy
ENABLE_HEDGING=true

# Hedge mode on Binance (one-way or hedge)
BINANCE_POSITION_MODE=one-way

# ============================================
# Emergency Configuration
# ============================================
# Enable emergency stop (disables all trading)
EMERGENCY_STOP=false
